# Canonical .env.example — commit this; copy to .env (gitignored) for local dev.
#
# Loaded by `node --env-file-if-exists=.env` in the dev/start scripts. In deployed
# environments no .env is present, so the flag is a no-op and real platform env
# vars always win. NEVER rely on .env in tests (inject via vitest config instead).
#
# Below are the common blocks. Delete the blocks that don't apply to your service.

# --- Server ---------------------------------------------------------------
PORT=3000

# --- Backend API (frontend/admin talking to a backend) --------------------
# For host-native dev this is localhost; the compose `environment:` block
# overrides it to the docker-internal service name when running in Docker.
# MY_BACKEND_ENDPOINT=http://localhost:3001

# --- Redis (session cache) ------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# USE_SINGLE_INSTANCE_CACHE=true

# --- Session cookie -------------------------------------------------------
# COOKIE_PASSWORD=this-is-a-secret-that-must-be-at-least-32-characters-long

# --- Postgres -------------------------------------------------------------
# POSTGRES_HOST=localhost
# POSTGRES_HOST_READ=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=my_db
# POSTGRES_GET_TOKEN_FROM_RDS=false

# --- OIDC / Entra (optional SSO) ------------------------------------------
# ENTRA_ENABLED=false
# ENTRA_TENANT_ID=
# ENTRA_WELL_KNOWN_URL=https://login.microsoftonline.com/<tenant-id>/v2.0/.well-known/openid-configuration
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_REDIRECT_URL=http://localhost:3000/auth/sign-in-oidc
# ENTRA_SIGN_OUT_REDIRECT_URL=http://localhost:3000
